{
  "hooks": [
    {
      "name": "error-alert",
      "trigger": { "type": "output-matches", "pattern": "(?i)error|exception", "stream": "STDERR" },
      "actions": [
        { "type": "notify", "title": "Error in {hook}", "body": "{line}" }
      ]
    },
    {
      "name": "build-finished",
      "trigger": { "type": "process-exits" },
      "actions": [
        { "type": "notify", "title": "Process finished", "body": "Exit code {exitCode}" },
        { "type": "webhook", "url": "https://example.com/terminal-watcher" }
      ]
    },
    {
      "name": "tests-passed",
      "trigger": { "type": "output-matches", "pattern": "BUILD SUCCESSFUL" },
      "actions": [
        { "type": "notify", "title": "Build green", "body": "{line}" }
      ],
      "once": true
    },
    {
      "name": "stalled",
      "trigger": { "type": "inactivity", "seconds": 120 },
      "actions": [
        { "type": "notify", "title": "No output", "body": "Silent for {idleSeconds} seconds" }
      ]
    },
    {
      "name": "log-deploys",
      "trigger": { "type": "output-matches", "pattern": "Deployed version (\\S+)" },
      "actions": [
        { "type": "run-command", "command": "echo {group1} >> deploys.log" }
      ],
      "enabled": false
    }
  ]
}
